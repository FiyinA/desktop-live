{
  "name": "desktop-live",
  "version": "1.0.0",
  "description": "Desktop Gemini Live - Screen sharing + Voice AI",
  "main": "src/main/main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win --x64",
    "pack": "electron-builder --dir"
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.0.0"
  },
  "dependencies": {
    "@google/genai": "^1.44.0",
    "electron-store": "^8.2.0"
  },
  "build": {
    "appId": "com.youname.desktoplive",
    "productName": "Desktop Live",
    "win": {
      "target": "nsis",
      "icon": "assets/icon.ico"
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false
    },
    "files": [
      "src/**/*",
      "assets/**/*",
      "node_modules/**/*"
    ]
  }
}
